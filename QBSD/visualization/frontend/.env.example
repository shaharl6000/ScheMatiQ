# Frontend Environment Variables for Railway Deployment
# These are embedded at build time (REACT_APP_ prefix required)

# Backend API URL - Set to your backend Railway service URL
REACT_APP_API_URL=https://your-backend.up.railway.app

# WebSocket URL (optional - derived from API URL if not set)
# REACT_APP_WS_URL=wss://your-backend.up.railway.app
