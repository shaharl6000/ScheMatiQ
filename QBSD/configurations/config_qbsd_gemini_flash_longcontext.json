{
  "query": "Given a protein sequence, can it be determined whether or not it contains a nuclear export signal (NES)? If it does, how strong is the NES, and what is the confidence in that assessment??",
  "docs_path": "../src/full_text",
  "max_keys_schema" : 100,
  "backend": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "max_tokens": 8192,
    "temperature": 0.2,
    "max_context_tokens": 1000000
  },
  "retriever": {
    "type": "embedding",
    "model_name": "all-MiniLM-L6-v2",
    "k": 100,
    "max_words": 25000,
    "batch_size": 1,
    "device": null,
    "enable_dynamic_k": true,
    "dynamic_k_threshold": 0.5,
    "dynamic_k_minimum": 30,
    "overlap_words": 128,
    "respect_structure": true
  },
  "output_path": "outputs/nes_exp_gemini_flash_longcontext_2.json"
}