# API Configuration
# For local development, leave empty to use relative /api path (proxy)
# For production/Railway, set to full backend URL
REACT_APP_API_URL=

# WebSocket URL (for real-time updates)
# For local development, leave empty or set to ws://localhost:8000
# For production/Railway, set to wss://<backend-service>.up.railway.app
REACT_APP_WS_URL=

# Feature Flags (optional)
REACT_APP_ENABLE_DEBUG=false
