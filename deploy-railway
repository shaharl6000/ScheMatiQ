#!/usr/bin/env bash
#
# deploy-railway - Railway deployment management for QueryDiscovery
#
# Prerequisites:
#   1. Create project and services in Railway dashboard first
#   2. Install Railway CLI: npm install -g @railway/cli
#   3. Link to your project: railway link
#
# Usage: ./deploy-railway <command> [options]
#

set -euo pipefail

# ============================================================================
# CONFIGURATION
# ============================================================================

readonly SCRIPT_VERSION="1.1.0"
readonly SCRIPT_NAME="deploy-railway"
readonly CONFIG_FILE=".railway-config"
readonly PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ============================================================================
# COLORS
# ============================================================================

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly CYAN='\033[0;36m'
readonly BOLD='\033[1m'
readonly NC='\033[0m'

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

error()   { echo -e "${RED}Error:${NC} $1" >&2; }
warn()    { echo -e "${YELLOW}Warning:${NC} $1" >&2; }
info()    { echo -e "${BLUE}Info:${NC} $1"; }
success() { echo -e "${GREEN}Success:${NC} $1"; }
header()  { echo -e "\n${BOLD}${CYAN}=== $1 ===${NC}\n"; }

die() {
    error "$1"
    exit "${2:-1}"
}

require_railway() {
    if ! command -v railway &> /dev/null; then
        die "Railway CLI not found.\n\nInstall with: npm install -g @railway/cli"
    fi
}

check_linked() {
    if ! railway status &> /dev/null; then
        die "Not linked to a Railway project.\n\nFirst:\n  1. Create project at https://railway.app/dashboard\n  2. Run: railway link"
    fi
}

prompt() {
    local message="$1"
    local default="${2:-}"
    local result
    if [[ -n "$default" ]]; then
        read -r -p "$message [$default]: " result
        echo "${result:-$default}"
    else
        read -r -p "$message: " result
        echo "$result"
    fi
}

# ============================================================================
# CONFIG FUNCTIONS
# ============================================================================

load_config() {
    if [[ -f "$PROJECT_ROOT/$CONFIG_FILE" ]]; then
        source "$PROJECT_ROOT/$CONFIG_FILE"
        return 0
    fi
    return 1
}

save_config() {
    cat > "$PROJECT_ROOT/$CONFIG_FILE" << EOF
# Railway Configuration for QueryDiscovery
# Generated on $(date)

BACKEND_SERVICE="${BACKEND_SERVICE:-}"
FRONTEND_SERVICE="${FRONTEND_SERVICE:-}"
BACKEND_URL="${BACKEND_URL:-}"
FRONTEND_URL="${FRONTEND_URL:-}"
EOF
    success "Configuration saved to $CONFIG_FILE"
}

# ============================================================================
# COMMAND: help
# ============================================================================

cmd_help() {
    echo -e "${BOLD}$SCRIPT_NAME${NC} v$SCRIPT_VERSION - Railway deployment for QueryDiscovery"
    echo ""
    echo -e "${BOLD}PREREQUISITES:${NC}"
    echo "    1. Create project & services at https://railway.app/dashboard"
    echo "    2. Install CLI: npm install -g @railway/cli"
    echo "    3. Login: railway login"
    echo "    4. Link project: railway link"
    echo ""
    echo -e "${BOLD}USAGE:${NC}"
    echo "    ./$SCRIPT_NAME <command> [options]"
    echo ""
    echo -e "${BOLD}COMMANDS:${NC}"
    echo "    setup                   Configure service names and save to .railway-config"
    echo "    deploy [target]         Deploy to Railway (backend, frontend, or all)"
    echo "    logs <service>          View service logs"
    echo "    env <service> <action>  Manage environment variables"
    echo "    status                  Show deployment status"
    echo "    open                    Open Railway dashboard"
    echo "    help                    Show this help"
    echo ""
    echo -e "${BOLD}DEPLOY TARGETS:${NC}"
    echo "    backend                 Deploy backend service"
    echo "    frontend                Deploy frontend service"
    echo "    all                     Deploy both (default)"
    echo ""
    echo -e "${BOLD}ENV ACTIONS:${NC}"
    echo "    list                    List all variables"
    echo "    set KEY=VALUE           Set a variable"
    echo "    delete KEY              Delete a variable"
    echo ""
    echo -e "${BOLD}EXAMPLES:${NC}"
    echo "    ./$SCRIPT_NAME setup"
    echo "    ./$SCRIPT_NAME deploy all"
    echo "    ./$SCRIPT_NAME deploy backend"
    echo "    ./$SCRIPT_NAME logs backend"
    echo "    ./$SCRIPT_NAME env backend list"
    echo "    ./$SCRIPT_NAME env backend set OPENAI_API_KEY=sk-xxx"
    echo "    ./$SCRIPT_NAME env frontend set REACT_APP_API_URL=https://..."
    echo ""
    echo -e "${BOLD}WORKFLOW:${NC}"
    echo "    1. Create project in Railway dashboard"
    echo "    2. Create 'backend' service (from GitHub or empty)"
    echo "    3. Create 'frontend' service (from GitHub or empty)"
    echo "    4. Run: railway link (select your project)"
    echo "    5. Run: ./$SCRIPT_NAME setup"
    echo "    6. Run: ./$SCRIPT_NAME deploy all"
}

# ============================================================================
# COMMAND: setup
# ============================================================================

cmd_setup() {
    header "Setup Railway Configuration"

    require_railway
    check_linked

    info "This will configure which Railway services to deploy to."
    echo ""

    # Get service names
    BACKEND_SERVICE=$(prompt "Backend service name" "backend")
    FRONTEND_SERVICE=$(prompt "Frontend service name" "frontend")

    echo ""
    info "Checking services exist..."

    # Verify services exist by trying to get their status
    if railway status --service "$BACKEND_SERVICE" &> /dev/null; then
        success "Backend service '$BACKEND_SERVICE' found"
    else
        warn "Backend service '$BACKEND_SERVICE' not found - create it in Railway dashboard"
    fi

    if railway status --service "$FRONTEND_SERVICE" &> /dev/null; then
        success "Frontend service '$FRONTEND_SERVICE' found"
    else
        warn "Frontend service '$FRONTEND_SERVICE' not found - create it in Railway dashboard"
    fi

    # Get URLs if available
    echo ""
    BACKEND_URL=$(prompt "Backend URL (leave empty if not deployed yet)" "")
    FRONTEND_URL=$(prompt "Frontend URL (leave empty if not deployed yet)" "")

    save_config

    echo ""
    header "Setup Complete"
    echo "Service configuration:"
    echo "  Backend:  $BACKEND_SERVICE"
    echo "  Frontend: $FRONTEND_SERVICE"
    echo ""
    echo "Next: ./$SCRIPT_NAME deploy all"
}

# ============================================================================
# COMMAND: deploy
# ============================================================================

deploy_with_retry() {
    local service_name="$1"
    local max_retries=3
    local retry=0

    while [[ $retry -lt $max_retries ]]; do
        if railway up --service "$service_name" --detach; then
            success "Deployment initiated for $service_name!"
            info "Check progress: railway logs --service $service_name"
            return 0
        fi
        retry=$((retry + 1))
        if [[ $retry -lt $max_retries ]]; then
            warn "Upload failed, retrying ($retry/$max_retries)..."
            sleep 5
        fi
    done
    return 1
}

cmd_deploy() {
    local target="${1:-all}"

    require_railway
    check_linked
    load_config || die "Run './$SCRIPT_NAME setup' first"

    cd "$PROJECT_ROOT"

    case "$target" in
        backend)
            header "Deploying Backend"
            [[ -z "$BACKEND_SERVICE" ]] && die "BACKEND_SERVICE not configured. Run setup first."
            info "Deploying to service: $BACKEND_SERVICE"
            info "This may take several minutes (ML dependencies)..."
            deploy_with_retry "$BACKEND_SERVICE" || die "Deployment failed after 3 attempts"
            ;;

        frontend)
            header "Deploying Frontend"
            [[ -z "$FRONTEND_SERVICE" ]] && die "FRONTEND_SERVICE not configured. Run setup first."
            info "Deploying to service: $FRONTEND_SERVICE"
            deploy_with_retry "$FRONTEND_SERVICE" || die "Deployment failed after 3 attempts"
            ;;

        all)
            header "Deploying All Services"

            [[ -z "$BACKEND_SERVICE" ]] && die "BACKEND_SERVICE not configured. Run setup first."
            [[ -z "$FRONTEND_SERVICE" ]] && die "FRONTEND_SERVICE not configured. Run setup first."

            info "Deploying backend to: $BACKEND_SERVICE"
            deploy_with_retry "$BACKEND_SERVICE" || warn "Backend deployment had issues"

            echo ""
            info "Deploying frontend to: $FRONTEND_SERVICE"
            deploy_with_retry "$FRONTEND_SERVICE" || warn "Frontend deployment had issues"

            success "Deployment initiated!"
            ;;

        *)
            die "Unknown target: $target. Use 'backend', 'frontend', or 'all'"
            ;;
    esac

    echo ""
    info "View build progress at: https://railway.app/dashboard"
}

# ============================================================================
# COMMAND: logs
# ============================================================================

cmd_logs() {
    local service="${1:-}"
    shift || true

    [[ -z "$service" ]] && die "Usage: ./$SCRIPT_NAME logs <backend|frontend>"

    require_railway
    check_linked
    load_config || true

    local service_name=""
    case "$service" in
        backend)  service_name="${BACKEND_SERVICE:-backend}" ;;
        frontend) service_name="${FRONTEND_SERVICE:-frontend}" ;;
        *)        die "Unknown service: $service" ;;
    esac

    info "Fetching logs for: $service_name"
    railway logs --service "$service_name" "$@"
}

# ============================================================================
# COMMAND: env
# ============================================================================

cmd_env() {
    local service="${1:-}"
    local action="${2:-}"
    shift 2 || true

    [[ -z "$service" ]] && die "Usage: ./$SCRIPT_NAME env <backend|frontend> <list|set|delete> [args]"
    [[ -z "$action" ]] && die "Usage: ./$SCRIPT_NAME env <backend|frontend> <list|set|delete> [args]"

    require_railway
    check_linked
    load_config || true

    local service_name=""
    case "$service" in
        backend)  service_name="${BACKEND_SERVICE:-backend}" ;;
        frontend) service_name="${FRONTEND_SERVICE:-frontend}" ;;
        *)        die "Unknown service: $service" ;;
    esac

    case "$action" in
        list)
            header "Environment: $service_name"
            railway variables --service "$service_name" 2>/dev/null || warn "Could not list variables"
            ;;
        set)
            [[ -z "${1:-}" ]] && die "Usage: ./$SCRIPT_NAME env $service set KEY=VALUE"
            railway variables --set "$1" --service "$service_name" || die "Failed to set variable"
            success "Variable set on $service_name"
            ;;
        delete)
            [[ -z "${1:-}" ]] && die "Usage: ./$SCRIPT_NAME env $service delete KEY"
            railway variables --service "$service_name" | grep -q "^$1=" && \
                warn "Note: Railway CLI may not support variable deletion. Use Railway dashboard instead."
            ;;
        *)
            die "Unknown action: $action. Use 'list', 'set', or 'delete'"
            ;;
    esac
}

# ============================================================================
# COMMAND: status
# ============================================================================

cmd_status() {
    require_railway
    check_linked
    load_config || true

    header "Deployment Status"

    local backend_svc="${BACKEND_SERVICE:-backend}"
    local frontend_svc="${FRONTEND_SERVICE:-frontend}"

    echo -e "${BOLD}Backend ($backend_svc):${NC}"
    railway status --service "$backend_svc" 2>/dev/null || echo "  Not available"

    echo ""
    echo -e "${BOLD}Frontend ($frontend_svc):${NC}"
    railway status --service "$frontend_svc" 2>/dev/null || echo "  Not available"

    if [[ -n "${BACKEND_URL:-}" ]]; then
        echo ""
        info "Health check:"
        if curl -sf "${BACKEND_URL}/health" --max-time 5 &>/dev/null; then
            echo -e "  Backend: ${GREEN}OK${NC}"
        else
            echo -e "  Backend: ${YELLOW}Unreachable${NC}"
        fi
    fi
}

# ============================================================================
# COMMAND: open
# ============================================================================

cmd_open() {
    local url="https://railway.app/dashboard"
    info "Opening $url"

    if command -v open &>/dev/null; then
        open "$url"
    elif command -v xdg-open &>/dev/null; then
        xdg-open "$url"
    else
        echo "Open: $url"
    fi
}

# ============================================================================
# MAIN
# ============================================================================

main() {
    cd "$PROJECT_ROOT"

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case $1 in
            -v|--version) echo "$SCRIPT_NAME v$SCRIPT_VERSION"; exit 0 ;;
            -h|--help)    cmd_help; exit 0 ;;
            -*)           die "Unknown option: $1" ;;
            *)            break ;;
        esac
    done

    local command="${1:-help}"
    shift || true

    case "$command" in
        setup)  cmd_setup "$@" ;;
        deploy) cmd_deploy "$@" ;;
        logs)   cmd_logs "$@" ;;
        env)    cmd_env "$@" ;;
        status) cmd_status "$@" ;;
        open)   cmd_open "$@" ;;
        help)   cmd_help ;;
        *)      die "Unknown command: $command. Run './$SCRIPT_NAME help'" ;;
    esac
}

main "$@"
