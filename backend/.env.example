# Backend Environment Variables
# Copy this file to .env and fill in your values

# ===================
# Server Configuration
# ===================
# Railway automatically sets PORT
# PORT=8000
# HOST=0.0.0.0

# Debug mode (set to false in production)
DEBUG=false

# CORS - Comma-separated list of allowed origins
# For local development:
# ALLOWED_ORIGINS=http://localhost:3000
# For Railway production:
# ALLOWED_ORIGINS=https://your-frontend.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000

# ===================
# LLM API Keys
# ===================
# At least one of these is required for QBSD functionality

# OpenAI (recommended)
OPENAI_API_KEY=your_openai_key_here

# Together AI (alternative)
# TOGETHER_API_KEY=your_together_key_here

# Google Gemini (alternative)
# GEMINI_API_KEY=your_gemini_key_here

# ===================
# Storage Configuration
# ===================
# Storage backend: "local" (default) or "supabase"
# Local storage is ephemeral on Railway - data is lost on redeploy
# Use Supabase for persistent storage in production
STORAGE_BACKEND=local

# Supabase Configuration (required if STORAGE_BACKEND=supabase)
# Create these buckets in your Supabase dashboard: sessions, documents, data, exports
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# ===================
# QBSD Configuration
# ===================
# Default values for QBSD processing
# max_output_tokens is auto-detected per model from qbsd.core.model_specs
DEFAULT_TEMPERATURE=0.7
DEFAULT_RETRIEVAL_K=5
