# Docker ignore file for QueryDiscovery
# Reduces build context size for faster builds

# ============================================================================
# Git
# ============================================================================
.git
.gitignore
.gitattributes

# ============================================================================
# Python
# ============================================================================
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.Python
**/*.egg-info
**/.eggs
.venv
venv
.pytest_cache
.mypy_cache
.ruff_cache

# ============================================================================
# Node
# ============================================================================
**/node_modules
# frontend/build - DO NOT ignore, needed for frontend Docker build
frontend/.next
frontend/coverage

# ============================================================================
# IDE & Editors
# ============================================================================
.idea
.vscode
*.swp
*.swo
*~
.project
.settings

# ============================================================================
# Environment & Secrets
# ============================================================================
**/.env
**/.env.*
!**/.env.example
.railway-config

# ============================================================================
# Research Data (large files - not needed in container)
# ============================================================================
research/

# ============================================================================
# Documentation (not needed in container)
# ============================================================================
docs/
*.md
!README.md

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ============================================================================
# Temporary & Cache
# ============================================================================
tmp/
temp/
*.tmp
*.temp
*.log
cache/

# ============================================================================
# Backend Data Directories
# ============================================================================
backend/app/data/
backend/app/sessions/
backend/app/qbsd_work/

# ============================================================================
# Test & Coverage
# ============================================================================
**/coverage
**/.coverage
**/htmlcov
**/.tox
**/.nox

# ============================================================================
# Build Artifacts
# ============================================================================
/build/
dist/
# Explicitly include frontend build (negates any previous patterns)
!frontend/build/
*.egg
*.whl

# ============================================================================
# Claude/AI Files
# ============================================================================
.claude/
CLAUDE.md
