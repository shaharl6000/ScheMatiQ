{
  "query_config_path": "configurations/config_qbsd_gemini_flash_longcontext.json",
  "data_path_override": "outputs/value_extractions/gemini_longcontext/values_nes_gemini_longcontext_all2_more_outtokens.json",

  "few_shot_config": {
    "n_shots_per_category": 2,
    "selection_strategy": "stratified",
    "specific_rows": [],
    "prefer_complete_rows": true,
    "min_completeness_ratio": 0.7
  },

  "evaluator_config": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "max_tokens": 8192,
    "temperature": 0.2
  },

  "comparison_config": {
    "default_strategy": "auto",
    "binary_threshold": 0.8,
    "sequence_similarity_threshold": 0.85
  },
  "gt_options": {
    "binary_options": ["yes", "in doubt", "no"]
  },

  "evaluation_metrics": [
    "accuracy",
    "confidence",
    "completeness",
    "column_utilization"
  ],

  "output_config": {
    "save_individual_results": true,
    "include_reasoning": true,
    "generate_summary_report": true
  }
}
